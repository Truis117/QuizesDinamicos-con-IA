{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start:prod": "node ./scripts/start-prod.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "node ./scripts/prisma-with-db-url.mjs generate",
    "prisma:migrate": "node ./scripts/prisma-with-db-url.mjs migrate dev --name init",
    "prisma:push": "node ./scripts/prisma-with-db-url.mjs db push",
    "prisma:deploy": "node ./scripts/prisma-with-db-url.mjs migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@quiz/contracts": "workspace:*",
    "argon2": "^0.41.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "prisma": "^6.19.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
