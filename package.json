{
  "name": "quizdinamico-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r build",
    "start": "pnpm prisma:deploy && pnpm --filter backend start",
    "typecheck": "pnpm -r typecheck",
    "prisma:generate": "pnpm --filter backend prisma:generate",
    "prisma:migrate": "pnpm --filter backend prisma:migrate",
    "prisma:deploy": "pnpm --filter backend prisma:deploy"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
